{
  "name": "rule-trace",
  "version": "1.2.0",
  "description": "Make AI-agent rule application visible and auditable: stable rule IDs, a catalog, trace blocks, usage counters, and a deterministic validator. Installable across Claude Code, OpenCode, and Codex via the Agent Skills standard.",
