    "skills",
    "hooks",
    ".claude-plugin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude-code",
    "agent-skills",
    "skills.sh",
    "opencode",
    "codex",
    "ai-agents",
    "rules",
    "tracing",
    "governance"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seanleecoder/rule-trace.git"
  },
